# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# WebSocket address of your ESP32 (from Arduino Serial Monitor)
ESP32_WS_ADDR=ws://192.168.1.74:81/ws

# Secret key used to sign session cookies.
# Generate a strong random value for production:
#   openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# HTTP port the server listens on (default: 8080)
PORT=8080

# Path to the SQLite database file (default: data/animations.db)
DB_PATH=data/animations.db

# Number of LEDs on the strip (default: 99)
NUM_LEDS=99
