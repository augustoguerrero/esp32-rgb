// PowerToggle renders a power on/off button
templ PowerToggle(isOn bool) {
	<form class="mb-4">
		<input type="hidden" name="power"
			if isOn {
				value="off"
			} else {
				value="on"
			}
		/>
		<button
			hx-post="/set-power"
			hx-target="body"
			hx-swap="outerHTML"
			if isOn {
				class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded"
			} else {
				class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded"
			}
		>
			if isOn {
				Turn Off
			} else {
				Turn On
			}
		</button>
	</form>
}

templ ControlPanel(currentBrightness string, currentAnimation string, brightnessComponent templ.Component, animationSelector templ.Component, isOn bool, showColorPicker bool, hue, sat, val, currentHex, satLeft, satRight, valRight string) {
	<div class="flex-center max-w-md mx-auto p-6 bg-gray-100 rounded-lg shadow-md">
		<h1 class="text-2xl font-bold text-center mb-4">LED Strip Control</h1>
		@PowerToggle(isOn)
		if showColorPicker {
			@ColorPicker(hue, sat, val, currentBrightness, currentHex, satLeft, satRight, valRight)
		}
		@brightnessComponent
		@animationSelector
	</div>
}